{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Transform": "AWS::Serverless-2016-10-31",
  "Description": "Enterprise syslog collection service using Proxylity UDP Gateway (WireGuard), Kinesis Firehose, CloudWatch Logs, and S3 with WORM archival.",
  "Parameters": {
    "ClientCidrToAllow": {
      "Description": "The CIDR restricting which IP addresses (WireGuard peer endpoints) may connect to the listener. Default is open/everyone. WireGuard cryptographic peer authentication is the primary access control; this provides an additional network-layer restriction.",
      "Type": "String",
      "Default": "0.0.0.0/0"
    },
    "PeerPublicKey": {
      "Description": "WireGuard public key for the first peer (e.g. your network gateway or router). Generate with: wg genkey | tee site1.key | wg pubkey > site1.pub. Additional peers can be added by editing the Peers list in the SyslogListener resource.",
      "Type": "String"
    },
    "LogGroupRetentionInDays": {
      "Description": "The number of days to retain logs in CloudWatch.",
      "Type": "Number",
      "Default": 7
    },
    "LogArchiveTransitionToGlacierInDays": {
      "Description": "The number of days to wait before transitioning log objects in S3 to Glacier.",
      "Type": "Number",
      "Default": 28
    },
    "LogArchiveExpirationInDays": {
      "Description": "The number of days to retain log objects in S3 before deleting them.",
      "Type": "Number",
      "Default": 365
    },
    "LogArchiveEncryptionKeyRotationInDays": {
      "Description": "The number of days to rotate the KMS key used to encrypt log objects in S3.",
      "Type": "Number",
      "Default": 365
    },
    "AlarmEmail": {
      "Description": "Optional email address to notify when a high-severity syslog alarm fires or when no messages are received for an extended period. Leave blank to provision the SNS topic without an email subscription.",
      "Type": "String",
      "Default": ""
    }
  },
  "Conditions": {
    "HasAlarmEmail": {
      "Fn::Not": [ { "Fn::Equals": [ { "Ref": "AlarmEmail" }, "" ] } ]
    }
  },
  "Mappings": {
    "ProxylityConfig": {
      "Fn::Transform": {
        "Name": "AWS::Include",
        "Parameters": {
          "Location": {
            "Fn::Sub": "s3://proxylity-config-${AWS::Region}/${AWS::AccountId}/customer-config.json"
          }
        }
      }
    }
  },
  "Resources": {
    "Key": {
      "Type": "AWS::KMS::Key",
      "Properties": {
        "Description": {
          "Fn::Sub": "KMS key for encrypting log data in S3 for stack ${AWS::StackName}."
        },
        "EnableKeyRotation": true,
        "RotationPeriodInDays": {
          "Ref": "LogArchiveEncryptionKeyRotationInDays"
        },
        "KeyPolicy": {
          "Version": "2012-10-17",
          "Id": "key-s3",
          "Statement": [
            {
              "Sid": "Enable IAM User Permissions",
              "Effect": "Allow",
              "Principal": {
                "AWS": {
                  "Fn::Join": [
                    "",
                    [
                      "arn:aws:iam::",
                      {
                        "Ref": "AWS::AccountId"
                      },
                      ":root"
                    ]
                  ]
                }
              },
              "Action": "kms:*",
              "Resource": "*"
            },
            {
              "Sid": "Allow S3 to use the key",
              "Effect": "Allow",
              "Principal": {
                "Service": "s3.amazonaws.com"
              },
              "Action": [
                "kms:Encrypt",
                "kms:Decrypt",
                "kms:ReEncrypt*",
                "kms:GenerateDataKey*",
                "kms:DescribeKey"
              ],
              "Resource": "*"
            },
            {
              "Sid": "Allow Firehose to use the key",
              "Effect": "Allow",
              "Principal": {
                "Service": "firehose.amazonaws.com"
              },
              "Action": [
                "kms:Encrypt",
                "kms:Decrypt",
                "kms:ReEncrypt*",
                "kms:GenerateDataKey*",
                "kms:DescribeKey"
              ],
              "Resource": "*"
            },
            {
              "Sid": "Allow CloudWatch to use the key",
              "Effect": "Allow",
              "Principal": {
                "Service": "logs.amazonaws.com"
              },
              "Action": [
                "kms:Encrypt",
                "kms:Decrypt",
                "kms:ReEncrypt*",
                "kms:GenerateDataKey*",
                "kms:DescribeKey"
              ],
              "Resource": "*"
            }
          ]
        }
      }
    },
    "Bucket": {
      "Type": "AWS::S3::Bucket",
      "Properties": {
        "BucketName": {
          "Fn::Sub": "${AWS::StackName}-${AWS::Region}"
        },
        "ObjectLockEnabled": true,
        "ObjectLockConfiguration": {
          "ObjectLockEnabled": "Enabled",
          "Rule": {
            "DefaultRetention": {
              "Mode": "GOVERNANCE",
              "Days": {
                "Ref": "LogArchiveExpirationInDays"
              }
            }
          }
        },
        "BucketEncryption": {
          "ServerSideEncryptionConfiguration": [
            {
              "ServerSideEncryptionByDefault": {
                "SSEAlgorithm": "aws:kms",
                "KMSMasterKeyID": {
                  "Fn::GetAtt": [ 
                    "Key",
                    "Arn"
                  ]
                }
              },
              "BucketKeyEnabled": true
            }
          ]
        },
        "LifecycleConfiguration": {
          "Rules": [
            {
              "Status": "Enabled",
              "ExpirationInDays": {
                "Ref": "LogArchiveExpirationInDays"
              },
              "Transitions": [
                {
                  "TransitionInDays": {
                    "Ref": "LogArchiveTransitionToGlacierInDays"
                  },
                  "StorageClass": "GLACIER"
                }
              ]
            }
          ]
        }
      }
    },
    "BucketPolicy": {
      "Type": "AWS::S3::BucketPolicy",
      "Properties": {
        "Bucket": {
          "Ref": "Bucket"
        },
        "PolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Sid": "SslIsRequired",
              "Action": "s3:*",
              "Effect": "Deny",
              "Resource": [
                {
                  "Fn::Sub": "${Bucket.Arn}"
                },
                {
                  "Fn::Sub": "${Bucket.Arn}/*"
                }
              ],
              "Condition": {
                "Bool": {
                  "aws:SecureTransport": "false"
                }
              },
              "Principal": "*"
            }
          ]
        }
      }
    },
    "DeliveryLogs": {
      "Type": "AWS::Logs::LogGroup",
      "Properties": {
        "LogGroupName": {
          "Fn::Sub": "/aws/kinesisfirehose/${AWS::StackName}-firehose-logs"
        },
        "RetentionInDays": {
          "Ref": "LogGroupRetentionInDays"
        }
      }
    },
    "DeliveryLogsStream": {
      "Type": "AWS::Logs::LogStream",
      "Properties": {
        "LogGroupName": {
          "Ref": "DeliveryLogs"
        },
        "LogStreamName": "delivery-errors"
      }
    },
    "Firehose": {
      "Type": "AWS::KinesisFirehose::DeliveryStream",
      "Properties": {
        "DeliveryStreamType": "DirectPut",
        "DirectPutSourceConfiguration": {
          "ThroughputHintInMBs": 1
        },
        "S3DestinationConfiguration": {
          "CloudWatchLoggingOptions": {
            "Enabled": true,
            "LogGroupName": {
              "Fn::Sub": "/aws/kinesisfirehose/${AWS::StackName}-firehose-logs"
            },
            "LogStreamName": "delivery-errors"
          },
          "BucketARN": {
            "Fn::GetAtt": [
              "Bucket",
              "Arn"
            ]
          },
          "BufferingHints": {
            "IntervalInSeconds": "60",
            "SizeInMBs": "50"
          },
          "EncryptionConfiguration": {
            "KMSEncryptionConfig": {
              "AWSKMSKeyARN": {
                "Fn::GetAtt": [ 
                  "Key",
                  "Arn"
                ]
              }
            }
          },
          "CompressionFormat": "UNCOMPRESSED",
          "Prefix": "syslog/",
          "RoleARN": {
            "Fn::GetAtt": [
              "FirehoseDeliveryRole",
              "Arn"
            ]
          }
        }
      }
    },
    "FirehoseDeliveryRole": {
      "Type": "AWS::IAM::Role",
      "Properties": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "firehose.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        }
      }
    },
    "FirehoseDeliveryPolicy": {
      "Type": "AWS::IAM::Policy",
      "Properties": {
        "PolicyName": "FirehoseDeliveryPolicy",
        "Roles": [
          {
            "Ref": "FirehoseDeliveryRole"
          }
        ],
        "PolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Action": [
                "s3:AbortMultipartUpload",
                "s3:GetBucketLocation",
                "s3:GetObject",
                "s3:ListBucket",
                "s3:ListBucketMultipartUploads",
                "s3:PutObject",
                "s3:PutObjectAcl",
                "s3:PutObjectTagging"
              ],
              "Resource": [
                {
                  "Fn::Sub": "${Bucket.Arn}/*"
                },
                {
                  "Fn::Sub": "${Bucket.Arn}"
                }
              ]
            },
            {
              "Effect": "Allow",
              "Action": [
                "kms:Encrypt",
                "kms:ReEncrypt*",
                "kms:Decrypt",
                "kms:GenerateDataKey*",
                "kms:Describe*"
              ],
              "Resource": [
                {
                  "Fn::GetAtt": [ 
                    "Key",
                    "Arn"
                  ]
                }
              ]
            },
            {
              "Effect": "Allow",
              "Action": [
                "logs:CreateLogGroup",
                "logs:CreateLogStream",
                "logs:PutLogEvents"
              ],
              "Resource": [
                {
                  "Fn::Sub": "${DeliveryLogs.Arn}"
                },
                {
                  "Fn::Sub": "${DeliveryLogs.Arn}/*"
                }
              ]
            }
          ]
        }
      }
    },
    "AlarmTopic": {
      "Type": "AWS::SNS::Topic",
      "Properties": {
        "TopicName": {
          "Fn::Sub": "${AWS::StackName}-syslog-alarms"
        }
      }
    },
    "AlarmTopicSubscription": {
      "Type": "AWS::SNS::Subscription",
      "Condition": "HasAlarmEmail",
      "Properties": {
        "TopicArn": { "Ref": "AlarmTopic" },
        "Protocol": "email",
        "Endpoint": { "Ref": "AlarmEmail" }
      }
    },
    "DestinationErrorLogs": {
      "Type": "AWS::Logs::LogGroup",
      "Properties": {
        "LogGroupName": {
          "Fn::Sub": "/proxylity-examples/syslog-destination-errors-${AWS::StackName}"
        },
        "RetentionInDays": {
          "Ref": "LogGroupRetentionInDays"
        }
      }
    },
    "Logs": {
      "Type": "AWS::Logs::LogGroup",
      "Properties": {
        "LogGroupName": {
          "Fn::Sub": "/proxylity-examples/syslog-cw-${AWS::StackName}"
        },
        "RetentionInDays": {
          "Ref": "LogGroupRetentionInDays"
        }
      }
    },
    "HighSeverityMetricFilter": {
      "Type": "AWS::Logs::MetricFilter",
      "Properties": {
        "LogGroupName": { "Ref": "Logs" },
        "FilterPattern": "?emerg ?alert ?crit",
        "MetricTransformations": [
          {
            "MetricNamespace": { "Fn::Sub": "${AWS::StackName}/Syslog" },
            "MetricName": "HighSeverityCount",
            "MetricValue": "1",
            "DefaultValue": 0,
            "Unit": "Count"
          }
        ]
      }
    },
    "MessageVolumeMetricFilter": {
      "Type": "AWS::Logs::MetricFilter",
      "Properties": {
        "LogGroupName": { "Ref": "Logs" },
        "FilterPattern": "",
        "MetricTransformations": [
          {
            "MetricNamespace": { "Fn::Sub": "${AWS::StackName}/Syslog" },
            "MetricName": "MessageCount",
            "MetricValue": "1",
            "DefaultValue": 0,
            "Unit": "Count"
          }
        ]
      }
    },
    "HighSeverityAlarm": {
      "Type": "AWS::CloudWatch::Alarm",
      "Properties": {
        "AlarmName": { "Fn::Sub": "${AWS::StackName}-syslog-high-severity" },
        "AlarmDescription": "One or more syslog messages with severity emerg, alert, or crit were received. Investigate immediately.",
        "Namespace": { "Fn::Sub": "${AWS::StackName}/Syslog" },
        "MetricName": "HighSeverityCount",
        "Statistic": "Sum",
        "Period": 300,
        "EvaluationPeriods": 1,
        "Threshold": 1,
        "ComparisonOperator": "GreaterThanOrEqualToThreshold",
        "TreatMissingData": "notBreaching",
        "AlarmActions": [ { "Ref": "AlarmTopic" } ],
        "OKActions": [ { "Ref": "AlarmTopic" } ]
      }
    },
    "PipelineSilenceAlarm": {
      "Type": "AWS::CloudWatch::Alarm",
      "Properties": {
        "AlarmName": { "Fn::Sub": "${AWS::StackName}-syslog-pipeline-silence" },
        "AlarmDescription": "No syslog messages have been received for 1 hour. The pipeline may be down or all sites may have lost connectivity to the listener.",
        "Namespace": { "Fn::Sub": "${AWS::StackName}/Syslog" },
        "MetricName": "MessageCount",
        "Statistic": "Sum",
        "Period": 3600,
        "EvaluationPeriods": 1,
        "Threshold": 1,
        "ComparisonOperator": "LessThanThreshold",
        "TreatMissingData": "breaching",
        "AlarmActions": [ { "Ref": "AlarmTopic" } ],
        "OKActions": [ { "Ref": "AlarmTopic" } ]
      }
    },
    "DestinationRole": {
      "Type": "AWS::IAM::Role",
      "Properties": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "AWS": {
                  "Fn::FindInMap": [
                    "ProxylityConfig",
                    {
                      "Ref": "AWS::Region"
                    },
                    "ServiceRole"
                  ]
                }
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "Policies": [
          {
            "PolicyName": "ProxylityExecutionPolicy",
            "PolicyDocument": {
              "Version": "2012-10-17",
              "Statement": [
                {
                  "Sid": "Firehose",
                  "Effect": "Allow",
                  "Action": [
                    "firehose:PutRecord",
                    "firehose:PutRecordBatch"
                  ],
                  "Resource": [
                    {
                      "Fn::GetAtt": [
                        "Firehose",
                        "Arn"
                      ]
                    }
                  ]
                },
                {
                  "Sid": "CloudWatch",
                  "Effect": "Allow",
                  "Action": [
                    "logs:CreateLogGroup",
                    "logs:CreateLogStream",
                    "logs:PutLogEvents"
                  ],
                  "Resource": [
                    {
                      "Fn::Sub": "${Logs.Arn}"
                    },
                    {
                      "Fn::Sub": "${Logs.Arn}/*"
                    },
                    {
                      "Fn::Sub": "${DestinationErrorLogs.Arn}"
                    },
                    {
                      "Fn::Sub": "${DestinationErrorLogs.Arn}/*"
                    }
                  ]
                }
              ]
            }
          }
        ]
      }
    },
    "SyslogListener": {
      "Type": "Custom::ProxylityUdpGatewayListener",
      "Properties": {
        "ServiceToken": {
          "Fn::FindInMap": [
            "ProxylityConfig",
            {
              "Ref": "AWS::Region"
            },
            "ServiceToken"
          ]
        },
        "ApiKey": {
          "Fn::FindInMap": [
            "ProxylityConfig",
            "Account",
            "ApiKey"
          ]
        },
        "Protocols": [
          "wg"
        ],
        "DecapsulatedDelivery": true,
        "Peers": [
          {
            "PublicKey": {
              "Ref": "PeerPublicKey"
            },
            "AllowedIPs": [
              "0.0.0.0/0",
              "::/0"
            ]
          }
        ],
        "ClientRestrictions": {
          "Networks": [
            {
              "Ref": "ClientCidrToAllow"
            }
          ]
        },
        "Destinations": [
          {
            "Name": "SyslogFirehose",
            "Description": "This destination sends SYSLOG messages to S3 via Firehose for archival.",
            "Role": {
              "Arn": {
                "Fn::GetAtt": [
                  "DestinationRole",
                  "Arn"
                ]
              }
            },
            "Batching": {
              "Count": 1000,
              "TimeoutInSeconds": 30
            },
            "LogGroupName": {
              "Ref": "DestinationErrorLogs"
            },
            "DestinationArn": {
              "Fn::GetAtt": [
                "Firehose",
                "Arn"
              ]
            }
          },
          {
            "Name": "SyslogLogs",
            "Description": "This destination sends SYSLOG messages to CloudWatch.",
            "Role": {
              "Arn": {
                "Fn::GetAtt": [
                  "DestinationRole",
                  "Arn"
                ]
              }
            },
            "Batching": {
              "Count": 10,
              "TimeoutInSeconds": 10
            },
            "LogGroupName": {
              "Ref": "DestinationErrorLogs"
            },
            "DestinationArn": {
              "Fn::GetAtt": [
                "Logs",
                "Arn"
              ]
            }
          }
        ]
      }
    }
  },
  "Outputs": {
    "BucketName": {
      "Value": {
        "Ref": "Bucket"
      }
    },
    "LogGroup": {
      "Value": {
        "Ref": "Logs"
      }
    },
    "Domain": {
      "Value": {
        "Fn::Sub": "${SyslogListener.Domain}.proxylity.com"
      }
    },
    "Port": {
      "Value": {
        "Fn::GetAtt": [
          "SyslogListener",
          "Port"
        ]
      }
    },
    "ListenerPublicKey": {
      "Description": "The WireGuard public key of the listener. Provide this to each peer in its [Peer] configuration as PublicKey.",
      "Value": {
        "Fn::GetAtt": [
          "SyslogListener",
          "WireGuardPublicKey"
        ]
      }
    },
    "AlarmTopicArn": {
      "Description": "SNS topic ARN for syslog alarms. Subscribe additional endpoints (email, Lambda, PagerDuty, etc.) to this topic.",
      "Value": { "Ref": "AlarmTopic" }
    },
    "DestinationErrorLogGroup": {
      "Description": "CloudWatch log group for Proxylity destination delivery errors.",
      "Value": { "Ref": "DestinationErrorLogs" }
    }
  }
}